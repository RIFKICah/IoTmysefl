  Blynk.virtualWrite(VPIN_STATUS, p == 1 ? "Profil: Janggel" : "Profil: Baru");
}

// ==================== PARSING UART ====================
String uartBuffer = "";
void parseData(String data) {
  data.trim();
  if (data.startsWith("STATUS")) return;
  int c1 = data.indexOf(','), c2 = data.indexOf(',', c1+1), c3 = data.indexOf(',', c2+1);
  if (c1==-1 || c2==-1 || c3==-1) return;
  int zona = data.substring(0,c1).toInt();
  float su = data.substring(c1+1,c2).toFloat();
  float hu = data.substring(c2+1,c3).toFloat();
  float me = data.substring(c3+1).toFloat();
  if (zona == 1) {
    zona1.suhu = su; zona1.kelembabanUdara = hu; zona1.kelembabanMedia = me;
    zona1.lastUpdate = millis(); zona1.valid = true;
  } else if (zona == 2) {
    zona2.suhu = su; zona2.kelembabanUdara = hu; zona2.kelembabanMedia = me;
    zona2.lastUpdate = millis(); zona2.valid = true;
  }
  durasiRelay = hitungDurasiGlobal();
  
  // Tandai bahwa ada data baru siap dikirim ke Blynk
  blynkDataReady = true;
}

// ==================== LCD ====================
unsigned long lastLCD = 0;
int page = 0;
void updateLCD() {
  // Hanya update tampilan data jika WiFi dalam keadaan normal (tidak sedang reconnect)
  // Agar tidak menimpa pesan reconnect, kita bisa tambahkan flag, tapi sederhana saja:
  // Kita manfaatkan millis() untuk menghindari konflik. Pesan reconnect akan menimpa layar.
  // Ini tidak masalah karena reconnect hanya sementara.
  if (millis() - lastLCD > 3000) {
    page = !page;
    lastLCD = millis();
  }
  lcd.clear();
  if (page == 0 && zona1.valid) {
    lcd.setCursor(0,0); lcd.print("Z1:"); lcd.print(zona1.suhu,1); lcd.print("C");
    lcd.setCursor(0,1); lcd.print("H:"); lcd.print(zona1.kelembabanUdara,0); lcd.print("% M:"); lcd.print(zona1.kelembabanMedia,0);
  } else if (zona2.valid) {
    lcd.setCursor(0,0); lcd.print("Z2:"); lcd.print(zona2.suhu,1); lcd.print("C");
    lcd.setCursor(0,1); lcd.print("H:"); lcd.print(zona2.kelembabanUdara,0); lcd.print("% M:"); lcd.print(zona2.kelembabanMedia,0);
  }
  // Indikator WiFi & relay
  if (WiFi.status() == WL_CONNECTED) {
    lcd.setCursor(0, 0);
    lcd.print("Wifi Connected");
  }
  lcd.setCursor(0, 1);
  lcd.print(relayState ? "Relay" : " ");
}

