// ==================== FUNGSI FUZZY ====================
float fuzzyTriangle(float x, float left, float peak, float right) {
  if (x <= left || x >= right) return 0.0;
  if (x <= peak) return (x - left) / (peak - left);
  return (right - x) / (right - peak);
}
float fuzzyTrapezoid(float x, float a, float b, float c, float d) {
  if (x <= a || x >= d) return 0.0;
  if (x >= b && x <= c) return 1.0;
  if (x < b) return (x - a) / (b - a);
  return (d - x) / (d - c);
}

float fuzzySuhuRendah(float s) { return fuzzyTrapezoid(s, profilAktif->T_rendah_left, profilAktif->T_rendah_peak_a, profilAktif->T_rendah_peak_b, profilAktif->T_rendah_right); }
float fuzzySuhuSedang(float s) { return fuzzyTrapezoid(s, profilAktif->T_sedang_a, profilAktif->T_sedang_b, profilAktif->T_sedang_c, profilAktif->T_sedang_d); }
float fuzzySuhuTinggi(float s) { return fuzzyTrapezoid(s, profilAktif->T_tinggi_left, profilAktif->T_tinggi_peak_a, profilAktif->T_tinggi_peak_b, profilAktif->T_tinggi_right); }
float fuzzyHumRendah(float h) { return fuzzyTrapezoid(h, profilAktif->H_rendah_left, profilAktif->H_rendah_peak_a, profilAktif->H_rendah_peak_b, profilAktif->H_rendah_right); }
float fuzzyHumSedang(float h) { return fuzzyTrapezoid(h, profilAktif->H_sedang_a, profilAktif->H_sedang_b, profilAktif->H_sedang_c, profilAktif->H_sedang_d); }
float fuzzyHumTinggi(float h) { return fuzzyTrapezoid(h, profilAktif->H_tinggi_left, profilAktif->H_tinggi_peak_a, profilAktif->H_tinggi_peak_b, profilAktif->H_tinggi_right); }
float fuzzyMediaKering(float m) { if (m >= profilAktif->M_kering_right) return 0.0; return (profilAktif->M_kering_right - m) / profilAktif->M_kering_right; }
float fuzzyMediaBasah(float m) { if (m <= profilAktif->M_basah_left) return 0.0; if (m >= 100.0) return 1.0; return (m - profilAktif->M_basah_left) / (100.0 - profilAktif->M_basah_left); }

float tidak(float y) { if (y < 0.0 || y > 3.0) return 0.0; return (3.0 - y) / 3.0; }
float cepat(float y) { if (y < 2.0 || y > 10.0) return 0.0; if (y <= 5.0) return (y - 2.0) / 3.0; return (10.0 - y) / 5.0; }
float lama(float y) { if (y < 8.0 || y > 15.0) return 0.0; if (y <= 12.0) return (y - 8.0) / 4.0; return (15.0 - y) / 3.0; }

float hitungDurasiGlobal() {
  memset(agregasi, 0, sizeof(agregasi));
  for (int z = 0; z < 2; z++) {
    float s, h, m; bool ok = false;
    if (z == 0 && zona1.valid) { s = zona1.suhu; h = zona1.kelembabanUdara; m = zona1.kelembabanMedia; ok = true; }
    else if (z == 1 && zona2.valid) { s = zona2.suhu; h = zona2.kelembabanUdara; m = zona2.kelembabanMedia; ok = true; }
    if (!ok) continue;

    float sR = fuzzySuhuRendah(s), sS = fuzzySuhuSedang(s), sT = fuzzySuhuTinggi(s);
    float hR = fuzzyHumRendah(h), hS = fuzzyHumSedang(h), hT = fuzzyHumTinggi(h);
    float mK = fuzzyMediaKering(m), mB = fuzzyMediaBasah(m);

    struct { float* m; float* s; float* h; int out; } aturan[18] = {
      {&mB, &sT, &hR, 1}, {&mB, &sT, &hS, 1}, {&mB, &sT, &hT, 0},
      {&mB, &sS, &hR, 1}, {&mB, &sS, &hS, 0}, {&mB, &sS, &hT, 0},
      {&mB, &sR, &hR, 0}, {&mB, &sR, &hS, 0}, {&mB, &sR, &hT, 0},
      {&mK, &sT, &hR, 2}, {&mK, &sT, &hS, 2}, {&mK, &sT, &hT, 2},
      {&mK, &sS, &hR, 2}, {&mK, &sS, &hS, 2}, {&mK, &sS, &hT, 1},
      {&mK, &sR, &hR, 1}, {&mK, &sR, &hS, 1}, {&mK, &sR, &hT, 1}
    };

    for (int i = 0; i < 18; i++) {
      float a = *(aturan[i].m), b = *(aturan[i].s), c = *(aturan[i].h);
      float alpha = min(a, min(b, c));
      if (alpha == 0.0) continue;
      for (int j = 0; j < RESOLUSI; j++) {
        float y = DURASI_MIN + j * STEP, muAsli;
        if (aturan[i].out == 0) muAsli = tidak(y);
        else if (aturan[i].out == 1) muAsli = cepat(y);
        else muAsli = lama(y);
        agregasi[j] = max(agregasi[j], min(alpha, muAsli));
      }
    }
  }
  float num = 0, den = 0;
  for (int j = 0; j < RESOLUSI; j++) {
    float y = DURASI_MIN + j * STEP, mu = agregasi[j];
    num += y * mu; den += mu;
  }
  return (den == 0) ? 0 : num / den;
}

