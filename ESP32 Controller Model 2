// ==================== LOOP ====================
void loop() {
  Blynk.run();

  // Cek koneksi WiFi & Blynk
  if (millis() - lastWifiCheck >= WIFI_CHECK_INTERVAL) {
    lastWifiCheck = millis();
    cekDanReconnectWiFi();
  }
  if (WiFi.status() == WL_CONNECTED && !Blynk.connected()) {
    if (millis() - lastBlynkReconnect >= BLYNK_RECONNECT_INTERVAL) {
      lastBlynkReconnect = millis();
      cekDanReconnectBlynk();
    }
  }

  // Kirim profil saat baru konek
  if (Blynk.connected() && !blynkSentProfile) {
    blynkSentProfile = true;
    int current = (profilAktif == &profilBaru) ? 2 : 1;
    Blynk.virtualWrite(VPIN_PROFIL_FB, current);
    Blynk.virtualWrite(VPIN_STATUS, current == 1 ? "Profil: Janggel" : "Profil: Baru");
  } else if (!Blynk.connected()) {
    blynkSentProfile = false;
  }

  // Polling UART 30 menit
  if (millis() - lastPollMaster >= POLL_INTERVAL) {
    lastPollMaster = millis();
    Serial2.print("GETDATA\n");
  }

  // Baca data dari UART
  while (Serial2.available()) {
    char c = Serial2.read();
    if (c == '\n') { parseData(uartBuffer); uartBuffer = ""; }
    else uartBuffer += c;
  }

  // Kontrol relay
  if (manualOverride) {
    if (manualRelayState && !relayState) {
      digitalWrite(RELAY_PIN, HIGH); relayState = true;
    } else if (!manualRelayState && relayState) {
      digitalWrite(RELAY_PIN, LOW); relayState = false;
      manualOverride = false; // kembali otomatis
    }
  } else {
    if (durasiRelay > 0 && !relayState && (zona1.valid || zona2.valid)) {
      digitalWrite(RELAY_PIN, HIGH); relayState = true; relayStart = millis();
    }
    if (relayState && millis() - relayStart >= durasiRelay * 1000) {
      digitalWrite(RELAY_PIN, LOW); relayState = false; durasiRelay = 0;
    }
  }

  updateLCD();

//  if (millis() - lastBlynkSend >= 2000) {
//    lastBlynkSend = millis();
//    kirimBlynk();
//  }

  // Timeout sensor
  if (zona1.valid && millis() - zona1.lastUpdate > 30000) zona1.valid = false;
  if (zona2.valid && millis() - zona2.lastUpdate > 30000) zona2.valid = false;

  // Restart tiap 6 jam
  if (millis() > RESTART_INTERVAL) {
    Serial.println("Restart setelah 6 jam...");
    delay(100);
    ESP.restart();
  }
  // Kirim ke Blynk hanya jika ada data baru dan Blynk terhubung
  if (blynkDataReady && Blynk.connected()) {
      kirimBlynk();
      blynkDataReady = false;  // Reset flag setelah dikirim
  }

  delay(10);
}
